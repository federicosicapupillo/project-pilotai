# Stripe publishable key (LIVE) — safe to ship to the browser.
# Vite inlines VITE_* variables at build time, so this is NOT a secret
# and must NOT be added to Lovable Secrets (which rejects the VITE_ prefix).
# Replace the value below with your real pk_live_... key.
VITE_PAYMENTS_CLIENT_TOKEN="pk_live_REPLACE_WITH_YOUR_LIVE_PUBLISHABLE_KEY"